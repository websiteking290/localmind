# =================================================================
#  Git Line Ending Rules - Portable AI USB
#  Prevents CRLF corruption when cloning on Windows
# =================================================================

# Default: normalize all text files to LF
* text=auto eol=lf

# Shell scripts must always use LF (Unix line endings)
*.sh text eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicitly binary files (no line ending conversion)
*.gz binary
*.tar binary
*.zip binary
*.node binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
