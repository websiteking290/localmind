<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - LocalMind</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-white min-h-screen">

<div class="min-h-screen">
  <header class="border-b border-gray-800 bg-gray-900/50">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <span class="font-semibold">LocalMind Admin</span>
      </div>
      <a href="/dashboard" class="text-sm text-gray-400 hover:text-white transition">Back to Dashboard</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">
    <div id="message" class="hidden mb-6 p-4 rounded-lg"></div>

    <div class="grid grid-cols-3 gap-6 mb-8" id="stats">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
        <p class="text-sm text-gray-500 mb-1">Total Users</p>
        <p class="text-3xl font-bold" id="statUsers">0</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
        <p class="text-sm text-gray-500 mb-1">Paid Users</p>
        <p class="text-3xl font-bold text-green-400" id="statPaid">0</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
        <p class="text-sm text-gray-500 mb-1">Total Updates</p>
        <p class="text-3xl font-bold text-blue-400" id="statUpdates">0</p>
      </div>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold">Manage Updates</h2>
        <button onclick="toggleForm()" id="formToggle" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
          New Update
        </button>
      </div>

      <form id="updateForm" onsubmit="handleSubmit(event)" class="hidden space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Version</label>
            <input type="text" id="version" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500" placeholder="v1.2.0">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Title</label>
            <input type="text" id="title" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500" placeholder="Update title">
          </div>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Description</label>
          <textarea id="description" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500 h-24" placeholder="What's new in this update?"></textarea>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Download URL</label>
          <input type="url" id="downloadUrl" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-blue-500" placeholder="https://cdn.localmind.ai/v1.2.0/LocalMind-v1.2.0.zip">
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition">
          Create Update
        </button>
      </form>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-800">
          <tr>
            <th class="text-left px-6 py-3 text-xs font-medium text-gray-400 uppercase">Version</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-gray-400 uppercase">Title</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-gray-400 uppercase">Date</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-gray-400 uppercase">Status</th>
            <th class="text-right px-6 py-3 text-xs font-medium text-gray-400 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody id="updatesTable" class="divide-y divide-gray-800">
        </tbody>
      </table>
    </div>
  </main>
</div>

<script>
let updates = [];

async function loadAdmin() {
  const [statsRes, updatesRes] = await Promise.all([
    fetch('/api/admin/stats'),
    fetch('/api/admin/updates'),
  ]);
  const stats = await statsRes.json();
  const updatesData = await updatesRes.json();
  
  document.getElementById('statUsers').textContent = stats.totalUsers;
  document.getElementById('statPaid').textContent = stats.paidUsers;
  document.getElementById('statUpdates').textContent = stats.totalUpdates;
  
  updates = updatesData.updates || [];
  renderUpdates();
}

function renderUpdates() {
  const tbody = document.getElementById('updatesTable');
  if (updates.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">No updates yet</td></tr>';
    return;
  }
  
  tbody.innerHTML = updates.map(u => `
    <tr class="hover:bg-gray-800/50 transition">
      <td class="px-6 py-4 text-sm">${u.version}</td>
      <td class="px-6 py-4 text-sm">${u.title}</td>
      <td class="px-6 py-4 text-sm text-gray-400">${new Date(u.release_date).toLocaleDateString()}</td>
      <td class="px-6 py-4">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${u.is_active ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-gray-500/10 text-gray-400 border border-gray-500/20'}">
          ${u.is_active ? 'Active' : 'Draft'}
        </span>
      </td>
      <td class="px-6 py-4 text-right">
        <button onclick="notifyUsers('${u.id}')" class="text-sm text-blue-400 hover:text-blue-300 transition">
          Notify Users
        </button>
      </td>
    </tr>
  `).join('');
}

function toggleForm() {
  const form = document.getElementById('updateForm');
  const btn = document.getElementById('formToggle');
  form.classList.toggle('hidden');
  btn.textContent = form.classList.contains('hidden') ? 'New Update' : 'Cancel';
}

async function handleSubmit(e) {
  e.preventDefault();
  const res = await fetch('/api/admin/updates', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      version: document.getElementById('version').value,
      title: document.getElementById('title').value,
      description: document.getElementById('description').value,
      downloadUrl: document.getElementById('downloadUrl').value,
    }),
  });
  
  const data = await res.json();
  if (res.ok) {
    showMessage('Update created!', 'success');
    toggleForm();
    document.getElementById('updateForm').reset();
    loadAdmin();
  } else {
    showMessage(data.error || 'Failed', 'error');
  }
}

async function notifyUsers(id) {
  const res = await fetch('/api/admin/notify', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ updateId: id }),
  });
  const data = await res.json();
  showMessage(data.message, 'success');
}

function showMessage(msg, type) {
  const el = document.getElementById('message');
  el.textContent = msg;
  el.className = `mb-6 p-4 rounded-lg ${type === 'success' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-red-500/10 text-red-400 border border-red-500/20'}`;
  el.classList.remove('hidden');
  setTimeout(() => el.classList.add('hidden'), 5000);
}

loadAdmin();
</script>

</body>
</html>