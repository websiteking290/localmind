<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - LocalMind</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-950 text-white min-h-screen">

<div class="min-h-screen">
  <header class="border-b border-gray-800 bg-gray-900/50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <span class="font-semibold">LocalMind</span>
      </div>
      <div class="flex items-center gap-4">
        <span id="userEmail" class="text-sm text-gray-400">Loading...</span>
        <button onclick="logout()" class="text-sm text-red-400 hover:text-red-300 transition">Log Out</button>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-8">
    <div class="mb-8 bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-lg font-semibold mb-1">License Status</h2>
          <div class="flex items-center gap-2 mb-2">
            <span id="licenseStatus" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">
              Loading...
            </span>
          </div>
          <div class="bg-gray-800 rounded-lg px-4 py-2 inline-block">
            <span class="text-xs text-gray-500">License Key: </span>
            <span id="licenseKey" class="text-sm font-mono text-blue-400">...</span>
          </div>
        </div>
        <a href="#" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition inline-flex items-center gap-2"
          onclick="alert('Download will be available when your order ships!')"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Download Software
        </a>
      </div>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-800">
        <h2 class="text-lg font-semibold">Available Updates</h2>
      </div>
      <div id="updatesList">
        <div class="px-6 py-12 text-center text-gray-500">Loading updates...</div>
      </div>
    </div>
  </main>
</div>

<script>
let userData = null;

async function loadDashboard() {
  try {
    const res = await fetch('/api/user');
    if (res.status === 401) {
      window.location.href = '/login';
      return;
    }
    userData = await res.json();
    renderDashboard();
  } catch (e) {
    console.error(e);
  }
}

function renderDashboard() {
  document.getElementById('userEmail').textContent = userData.user.email;
  document.getElementById('licenseKey').textContent = userData.user.license_key;
  
  const statusEl = document.getElementById('licenseStatus');
  if (userData.user.is_paid) {
    statusEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20';
    statusEl.textContent = 'Active';
  } else {
    statusEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20';
    statusEl.textContent = 'Trial';
  }

  const updates = userData.updates || [];
  const list = document.getElementById('updatesList');
  
  if (updates.length === 0) {
    list.innerHTML = '<div class="px-6 py-12 text-center text-gray-500">No updates available. You're on the latest version.</div>';
    return;
  }

  list.innerHTML = updates.map(u => `
    <div class="px-6 py-5 flex items-center justify-between border-b border-gray-800 last:border-0 hover:bg-gray-800/50 transition">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-1">
          <span class="bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded text-xs font-medium border border-blue-500/20">${u.version}</span>
          <span class="text-xs text-gray-500">${new Date(u.release_date).toLocaleDateString()}</span>
        </div>
        <h3 class="font-medium mb-1">${u.title}</h3>
        <p class="text-sm text-gray-400">${u.description || ''}</p>
      </div>
      <a href="${u.download_url}" target="_blank"
        class="ml-4 px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white transition"
      >
        Download
      </a>
    </div>
  `).join('');
}

async function logout() {
  await fetch('/api/auth/logout', { method: 'POST' });
  window.location.href = '/login';
}

loadDashboard();
</script>

</body>
</html>